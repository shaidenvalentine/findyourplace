# Find Your Place — environment template. Copy to .env.local and fill in.
# Everything is OPTIONAL for local dev (the app degrades gracefully), but the
# blocks marked [PROD] are required for a real launch.

# ─── Site ────────────────────────────────────────────────────────────────────
# Canonical origin — used for OG images, canonical URLs, sitemap, checkout redirects.
# Set this in Vercel or OG/canonical URLs will point at the default domain.
NEXT_PUBLIC_SITE_URL=https://findyourplace.app

# ─── Supabase [PROD — required] ──────────────────────────────────────────────
# Without these, runs + unlock state live only in-memory per serverless instance,
# so a Stripe/LS webhook on one instance won't unlock the results page on another —
# paying users stay locked out. runStore.ts uses these automatically when present.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Payment rail [PROD — pick ONE] ──────────────────────────────────────────
# Lemon Squeezy (launch default — merchant of record). ALL FOUR are required for
# the rail to be considered "live" (incl. the webhook secret — otherwise checkout
# would succeed but nothing could unlock). Point an order_created webhook at
# /api/lemonsqueezy/webhook. Set the LS variant price to match PRICE_CENTS ($29).
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# Stripe (alternative rail). Point a checkout.session.completed webhook at
# /api/stripe/webhook.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Force a rail when both are configured: lemonsqueezy | stripe
# PAYMENT_PROVIDER=lemonsqueezy

# ─── Admin / creator portal [PROD — required to use those portals] ───────────
# The repo is public, so in production the admin/creator login is DISABLED until
# BOTH of these are set to real values (the dev defaults never grant prod access).
SESSION_SECRET=
ADMIN_PASSWORD=

# ─── Resend (optional — transactional email) ─────────────────────────────────
# When set, paywall email captures get a "your results link" email so buyers and
# non-buyers can always return to their run. Verify your domain in Resend first.
RESEND_API_KEY=
# EMAIL_FROM="Find Your Place <hello@findyourplace.app>"

# ─── Anthropic (optional) ────────────────────────────────────────────────────
# Richer AI-profile parsing on Path A. Without it, the deterministic heuristic runs.
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ─── Meta Pixel + Conversions API (Phase 5 — before the first ad) ────────────
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_TOKEN=

# ─── Affiliate programs (see docs/AFFILIATES.md for signup order + link formats)
# Each var holds the FULL tracked URL from the partner's program. Unset = the
# card links to the plain site (no commission, still useful advice). An optional
# {CLICK_ID} placeholder is replaced per-click with an anonymous run/placement
# ref for conversion reconciliation, e.g.:
#   AFF_WISE=https://wise.prf.hn/click/camref:XXXX/pubref:{CLICK_ID}
#   AFF_AIRALO=https://airalo.pxf.io/XXXX?subId1={CLICK_ID}
# Income
AFF_DEEL=
AFF_DOOLA=
AFF_FLEXJOBS=
# Tax (Bright!Tax has no cash program — no var)
AFF_TAXESFOREXPATS=
# Banking
AFF_WISE=
AFF_MERCURY=
# Insurance
AFF_SAFETYWING=
AFF_INSUREDNOMADS=
AFF_GENKI=
# Get there
AFF_IVISA=
AFF_ANYTIMEMAILBOX=
AFF_SIRELO=
AFF_SKYSCANNER=
# First place
AFF_BLUEGROUND=
AFF_FLATIO=
AFF_TRUSTEDHOUSESITTERS=
AFF_BOOKING=
# Land softly (Coworker has no program — no var)
AFF_NORDVPN=
AFF_AIRALO=
AFF_LINGODA=
AFF_ITALKI=

# ─── Images (build-time only, for scripts/fetch-location-images.mjs) ─────────
# UNSPLASH_ACCESS_KEY=
